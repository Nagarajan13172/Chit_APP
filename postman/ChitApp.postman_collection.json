{
  "info": {
    "name": "Chit Collection Management System",
    "description": "API collection. Run 'Auth > Login (Admin)' first — it auto-saves {{token}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "  console.log('Saved token');",
                  "}",
                  "pm.test('login ok', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@chit.com\",\n  \"password\": \"Admin@123\"\n}" }
          }
        },
        {
          "name": "Login (Agent)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) { pm.collectionVariables.set('token', json.data.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"agent@chit.com\",\n  \"password\": \"Agent@123\"\n}" }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Create User (Admin only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/users", "host": ["{{baseUrl}}"], "path": ["auth", "users"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"New Agent\",\n  \"email\": \"newagent@chit.com\",\n  \"password\": \"Agent@123\",\n  \"role\": \"AGENT\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/customers", "host": ["{{baseUrl}}"], "path": ["customers"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Vijay Anand\",\n  \"phone\": \"9000099999\",\n  \"email\": \"vijay@example.com\",\n  \"address\": \"12 South St\",\n  \"area\": \"Adyar\"\n}" }
          }
        },
        {
          "name": "List Customers (paged + filters)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/customers?page=1&limit=10&search=&area=&sortBy=createdAt&sortOrder=desc",
              "host": ["{{baseUrl}}"],
              "path": ["customers"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "" },
                { "key": "area", "value": "" },
                { "key": "sortBy", "value": "createdAt" },
                { "key": "sortOrder", "value": "desc" }
              ]
            }
          }
        },
        {
          "name": "Search by Phone",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/customers/search?phone=987",
              "host": ["{{baseUrl}}"],
              "path": ["customers", "search"],
              "query": [{ "key": "phone", "value": "987" }]
            }
          }
        },
        {
          "name": "Get Customer by Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/customers/1", "host": ["{{baseUrl}}"], "path": ["customers", "1"] }
          }
        },
        {
          "name": "Update Customer",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/customers/1", "host": ["{{baseUrl}}"], "path": ["customers", "1"] },
            "body": { "mode": "raw", "raw": "{\n  \"area\": \"T. Nagar\",\n  \"email\": \"\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Chit Plans",
      "item": [
        {
          "name": "Create Plan (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/plans", "host": ["{{baseUrl}}"], "path": ["plans"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Gold Monthly - G24\",\n  \"chitValue\": 500000,\n  \"durationMonths\": 24,\n  \"totalMembers\": 24,\n  \"startDate\": \"2025-07-01\"\n}" }
          }
        },
        {
          "name": "List Plans (paged + filters)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/plans?page=1&limit=10&status=ACTIVE&search=",
              "host": ["{{baseUrl}}"],
              "path": ["plans"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "status", "value": "ACTIVE" },
                { "key": "search", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Get Plan by Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/plans/1", "host": ["{{baseUrl}}"], "path": ["plans", "1"] }
          }
        },
        {
          "name": "Assign Customer to Plan (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/plans/1/members", "host": ["{{baseUrl}}"], "path": ["plans", "1", "members"] },
            "body": { "mode": "raw", "raw": "{\n  \"customerId\": 4\n}" }
          }
        },
        {
          "name": "List Plan Members",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/plans/1/members", "host": ["{{baseUrl}}"], "path": ["plans", "1", "members"] }
          }
        }
      ]
    },
    {
      "name": "Collections",
      "item": [
        {
          "name": "Membership Installment Schedule",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/memberships/1/installments", "host": ["{{baseUrl}}"], "path": ["memberships", "1", "installments"] }
          }
        },
        {
          "name": "Customer Collection History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/customers/1/history", "host": ["{{baseUrl}}"], "path": ["customers", "1", "history"] }
          }
        },
        {
          "name": "Customer Pending Amount",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/customers/1/pending", "host": ["{{baseUrl}}"], "path": ["customers", "1", "pending"] }
          }
        }
      ]
    },
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      }
    }
  ]
}
